---
layout: default
---
{% assign member = site.data.members.members | where: "slug", page.member_id | first %}
{% assign ko = false %}
{% if site.active_lang == "ko" %}{% assign ko = true %}{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if ko and member.name_kr %}{{ member.name_kr }} <span style="font-weight:400;color:var(--global-text-color-light);font-size:0.7em;">({{ member.name }})</span>
      {% else %}{{ member.name }}{% if member.name_kr %} <span style="font-weight:400;color:var(--global-text-color-light);font-size:0.7em;">({{ member.name_kr }})</span>{% endif %}{% endif %}
    </h1>
    <p class="post-description">{{ member.role }}</p>
  </header>

  <article>
    <div class="row">
      {% if member.image %}
        <div class="col-sm-4 mb-3">
          <img class="member-profile-photo" src="{{ '/assets/img/' | append: member.image | relative_url }}" alt="{{ member.name }}" loading="eager">
        </div>
      {% endif %}
      <div class="col">
        {% if member.detail %}<p class="member-bio">{{ member.detail }}</p>{% endif %}
        {% if member.scholar %}<p><a href="{{ member.scholar }}">Google Scholar</a></p>{% endif %}
      </div>
    </div>

    {% if member.papers and member.papers.size > 0 %}
      <h2>{% if ko %}논문{% else %}Papers{% endif %}</h2>
      <ul class="pub-list">
        {% for item in member.papers %}
          {% assign clean = item | remove: "** scheduled" | strip %}
          <li>{{ clean }}{% if item contains "scheduled" %} <span class="pub-status">{% if ko %}예정{% else %}scheduled{% endif %}</span>{% endif %}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if member.papers_in_progress and member.papers_in_progress.size > 0 %}
      <h2>{% if ko %}진행 중 논문{% else %}Papers in Progress{% endif %}</h2>
      <ul class="pub-list">
        {% for item in member.papers_in_progress %}
          {% assign clean = item | remove: "** scheduled" | strip %}
          <li>{{ clean }}{% if item contains "scheduled" %} <span class="pub-status">{% if ko %}예정{% else %}scheduled{% endif %}</span>{% endif %}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if member.talks and member.talks.size > 0 %}
      <h2>{% if ko %}발표{% else %}Talks{% endif %}</h2>
      <ul class="pub-list">
        {% for item in member.talks %}
          {% assign clean = item | remove: "** scheduled" | strip %}
          <li>{{ clean }}{% if item contains "scheduled" %} <span class="pub-status">{% if ko %}예정{% else %}scheduled{% endif %}</span>{% endif %}</li>
        {% endfor %}
      </ul>
    {% endif %}

    <p class="mt-4"><a href="{{ '/people/' | relative_url }}">&larr; {% if ko %}구성원 전체{% else %}All members{% endif %}</a></p>
  </article>
</div>
